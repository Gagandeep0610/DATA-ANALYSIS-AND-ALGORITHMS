#include <stdio.h>
#include <stdlib.h>

int count = 0;
int a[10];

int compare(int x, int y) {
    count++;
    return x > y;
}

void bubblesort(int n) {
    int i, j, temp;
    for (i = 0; i < n - 1; i++) {
        for (j = 0; j < n - i - 1; j++) {
            if (compare(a[j], a[j + 1])) {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }
    }
}

int main() {
    int n, i;
    printf("Enter array size: ");
    scanf("%d", &n);

    printf("Enter array elements:\n");
    for (i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    bubblesort(n);

    printf("Sorted elements are:\n");
    for (i = 0; i < n; i++) {
        printf("%d\t", a[i]);
    }

    printf("\nTotal number of comparisons = %d\n", count);

    return 0;
}
