#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define SIZE 256

int Table[SIZE];

void shift_table(char p[20])
{
    int i, m;
    m = strlen(p);

    for (i = 0; i < SIZE; i++)
        Table[i] = m;

    for (i = 0; i < m - 1; i++)
        Table[(int)p[i]] = m - 1 - i;
}

int horspool(char T[50], char p[20])
{
    int i, k, n, m;

    shift_table(p);

    n = strlen(T);
    m = strlen(p);

    i = m - 1;

    while (i <= n - 1)
    {
        k = 0;

        while (k < m && p[m - 1 - k] == T[i - k])
            k = k + 1;

        if (k == m)
            return i - m + 1;
        else
            i = i + Table[(int)T[i]];
    }

    return -1;
}

int main()
{
    char T[50], p[20];
    int pos;

    printf("\nRead Text:\n");
    scanf("%s", T);

    printf("\nRead Pattern:\n");
    scanf("%s", p);

    pos = horspool(T, p);

    if (pos == -1)
        printf("\nPattern not found");
    else
        printf("\nPattern found at position %d", pos);

    return 0;
}
